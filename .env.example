# 로컬 셸/스크립트 예시용 환경 변수
# 실제 배포 시크릿은 .streamlit/secrets.toml 또는 배포 플랫폼 시크릿을 우선 사용한다.

# 저장소 선택: auto | supabase | sqlite
PORTFOLIO_BACKEND=auto

# 로컬 SQLite 경로
RETIREMENT_DB_PATH=data/portfolio.db

# Supabase 앱 사용자 키
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_EMAIL_REDIRECT_TO=http://localhost:8501

# 관리자/배치 작업용 키
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ADMIN_KEY=
MIGRATION_SUPABASE_KEY_ENV=SUPABASE_KEY

# KIS 시세/실시간 연동
KIS_APP_KEY=your-kis-app-key
KIS_APP_SECRET=your-kis-app-secret
KIS_ENV=prod

# 배치/검증 기본값
ROLLUP_TIMEZONE=Asia/Seoul
STREAMLIT_APP_URL=http://localhost:8501
DEMO_LOGIN_EMAIL=demo@example.com
DEMO_LOGIN_PASSWORD=demo-password
STREAMLIT_VERIFY_EMAIL=you@example.com
STREAMLIT_VERIFY_PASSWORD=your-password
